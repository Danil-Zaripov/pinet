Add(r, x) >< S(y) =>
    Add(w, x) ~ y,
    r ~ S(w);

Add(r, x) >< Z() =>
    r ~ x;

Mul(r, x) >< S(y) =>
    Dup(x1, x2) ~ x,
    Mul(w, x1) ~ y,
    Add(r, w) ~ x2;


// Wildcard here is unnecessary,
// placed for demonstration purposes
Mul(r, x) >< y =>
    r ~ y,
    x ~ Eraser();

a ~ S(S(Z()));
b ~ S(S(S(Z())));
Mul(r, a) ~ b;
r;
